# ─────────────────────────────────────────────────────────────────────────────
# MoveMend — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── GEMINI AI ─────────────────────────────────────────────────────────────────
# Get your FREE API key from: https://aistudio.google.com/apikey
# Uses gemini-2.5-flash-lite (stable, free tier).
# SERVER ONLY — do not prefix with NEXT_PUBLIC_

GEMINI_API_KEY=your-gemini-api-key-here

# ── GESTURE COACH URL ─────────────────────────────────────────────────────────
# URL of the MoveMend Gesture Coach companion app.
# Development: run `cd gesture-coach && npm install && npm run dev` → port 5174
# Production: deploy gesture-coach/ to Vercel and paste the URL here.

NEXT_PUBLIC_GESTURE_COACH_URL=http://localhost:5174

# ── LIVE REVIEW URL (fallback) ────────────────────────────────────────────────
# Falls back to this if GESTURE_COACH_URL is not set.
# Usually the same as the gesture coach URL.

NEXT_PUBLIC_LIVE_REVIEW_URL=/live-review

# ─────────────────────────────────────────────────────────────────────────────
# QUICK START
# ─────────────────────────────────────────────────────────────────────────────
#
# Terminal 1 — MoveMend dashboard:
#   cd movemend-next && npm install && npm run dev   → http://localhost:3000
#
# Terminal 2 — Gesture Coach:
#   cd gesture-coach && npm install && npm run dev   → http://localhost:5174
#
# For phone access (MediaPipe needs HTTPS):
#   Deploy gesture-coach/ to Vercel and update NEXT_PUBLIC_GESTURE_COACH_URL above.
